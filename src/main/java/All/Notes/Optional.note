@PostMapping("")
    public ResponseEntity<Contact> createContact( @RequestBody Contact contact){
        Contact savedContact = contactService.CreateContact(contact);
        URI location = ServletUriComponentsBuilder
                .fromCurrentRequest()
                .path("/{id}")
                .buildAndExpand(savedContact.getId())
                .toUri();
        return ResponseEntity.created(location).body(savedContact);}

 @GetMapping("/{id}")
    public ResponseEntity<Contact> getContacts(@PathVariable(value="id") String id){
        return ResponseEntity.ok().body(contactService.FindById(id));
    }
